<?xml version='1.0' encoding='UTF-8'?>

<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>

<!--
  Configuración mínima de Traccar.
  Toda la configuración real (BD, logs, geocoder) viene de variables
  de entorno definidas en docker-compose.yml gracias a:
    CONFIG_USE_ENVIRONMENT_VARIABLES=true
-->

<properties>
  <entry key='config.use_environment_variables'>true</entry>

  <!-- Deshabilita el Liquibase interno de Traccar.
       El schema es gestionado por traccar-db/migrations/ (nuestro Liquibase).
       Sin esto, Traccar busca ./schema/changelog-master.xml en /opt/traccar
       y falla porque esos archivos no se copian a la imagen runtime. -->
  <entry key='database.changelog'></entry>

  <!-- Puerto único de auto-detección de protocolo GPS.
       Todos los dispositivos conectan al 5055 y Traccar detecta el protocolo
       automáticamente del primer paquete. Elimina la necesidad del rango 5000-5150. -->
  <entry key='server.port'>5055</entry>
</properties>
